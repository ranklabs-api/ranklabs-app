---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Home" 
  description="{{site_description}}"
>
  <section class="hero">
    <h1>Welcome to {{site_name}}</h1>
    <p>{{site_description}}</p>
  </section>
  
  <section class="features">
    <h2>Our Services</h2>
    <div class="grid">
      <div class="card">
        <h3>Service One</h3>
        <p>Description of your first service.</p>
      </div>
      <div class="card">
        <h3>Service Two</h3>
        <p>Description of your second service.</p>
      </div>
      <div class="card">
        <h3>Service Three</h3>
        <p>Description of your third service.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { text-align: center; padding: 4rem 2rem; }
  .hero h1 { font-size: 3rem; margin-bottom: 1rem; }
  .features { padding: 2rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; }
  .card { padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 0.5rem; }
</style>
